---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const proyectos = await getCollection('proyectos');
  return proyectos.map(proyecto => ({
    params: { slug: proyecto.id },
    props: { proyecto },
  }));
}

const { proyecto } = Astro.props;
const { Content } = await render(proyecto);
const { titulo, descripcion, categoria, fecha, tags, imagenPortada, galeria, enlaces } =
  proyecto.data;

const categoriaLabel = categoria === 'electronica' ? 'Electrónica' : 'Software';
const fechaFormateada = fecha.toLocaleDateString('es', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${titulo} — Mi Portfolio`} description={descripcion}>
  <div class="detail-wrap">
    <a href={import.meta.env.BASE_URL} class="back-link">← Volver</a>

    <header class="detail-header">
      <div class="detail-meta">
        <span class={`badge-cat badge-cat--${categoria}`}>{categoriaLabel}</span>
        <time datetime={fecha.toISOString()}>{fechaFormateada}</time>
      </div>
      <h1 class="detail-title">{titulo}</h1>
      <p class="detail-desc">{descripcion}</p>
      {tags.length > 0 && (
        <ul class="tags-list" aria-label="Tags">
          {tags.map(tag => <li class="tag">{tag}</li>)}
        </ul>
      )}
    </header>

    {imagenPortada && (
      <div class="detail-cover">
        <Image src={imagenPortada} alt={titulo} width={1100} height={688} loading="eager" />
      </div>
    )}

    {enlaces && (
      <div class="enlaces-bar">
        {enlaces.repo && (
          <a href={enlaces.repo} target="_blank" rel="noopener noreferrer" class="enlace-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.39.6.11.82-.26.82-.58 0-.28-.01-1.04-.01-2.04-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02 0 2.04.14 3 .4 2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22 0 1.6-.01 2.9-.01 3.29 0 .32.21.7.82.58C20.56 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            Repositorio
          </a>
        )}
        {enlaces.demo && (
          <a href={enlaces.demo} target="_blank" rel="noopener noreferrer" class="enlace-btn enlace-btn--demo">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
            Demo
          </a>
        )}
        {enlaces.video && (
          <a href={enlaces.video} target="_blank" rel="noopener noreferrer" class="enlace-btn enlace-btn--video">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="5 3 19 12 5 21 5 3"/>
            </svg>
            Video
          </a>
        )}
      </div>
    )}

    <article class="prose">
      <Content />
    </article>

    {galeria && galeria.length > 0 && (
      <section class="galeria">
        <h2>Galería</h2>
        <div class="galeria-grid">
          {galeria.map((img, i) => (
            <Image src={img} alt={`${titulo} — imagen ${i + 1}`} width={600} height={375} loading="lazy" />
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
  .detail-wrap {
    max-width: 780px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 1.75rem;
    transition: color 0.15s;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--accent-light);
  }

  .detail-header {
    margin-bottom: 2rem;
  }

  .detail-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .badge-cat {
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge-cat--electronica {
    background: rgba(99, 102, 241, 0.2);
    color: var(--accent-light);
    border: 1px solid rgba(99, 102, 241, 0.3);
  }

  .badge-cat--software {
    background: rgba(16, 185, 129, 0.15);
    color: #6ee7b7;
    border: 1px solid rgba(16, 185, 129, 0.25);
  }

  .detail-title {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 800;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .detail-desc {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .tags-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    background: var(--tag-bg);
    color: var(--text-muted);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-family: monospace;
  }

  .detail-cover {
    border-radius: calc(var(--radius) * 1.5);
    overflow: hidden;
    margin-bottom: 2rem;
    border: 1px solid var(--border);
  }

  .detail-cover img {
    width: 100%;
    height: auto;
    display: block;
  }

  .enlaces-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .enlace-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 1rem;
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-weight: 600;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    color: var(--text);
    transition: border-color 0.15s, background 0.15s;
    text-decoration: none;
  }

  .enlace-btn:hover {
    border-color: var(--accent);
    background: var(--bg-surface-hover);
    text-decoration: none;
  }

  .enlace-btn--demo {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .enlace-btn--demo:hover {
    background: var(--accent-light);
    border-color: var(--accent-light);
  }

  /* Prose (rendered markdown) */
  .prose {
    line-height: 1.75;
    color: var(--text);
    font-size: 1rem;
  }

  .prose :global(h2) {
    font-size: 1.35rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 1.5rem 0 0.5rem;
    color: var(--text);
  }

  .prose :global(p) {
    margin-bottom: 1rem;
    color: var(--text-muted);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0.75rem 0 1rem 1.5rem;
    color: var(--text-muted);
  }

  .prose :global(li) {
    margin-bottom: 0.35rem;
  }

  .prose :global(code) {
    font-family: monospace;
    font-size: 0.88em;
    background: var(--tag-bg);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--accent-light);
  }

  .prose :global(pre) {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1rem 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    color: var(--text);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.9rem;
  }

  .prose :global(th) {
    text-align: left;
    padding: 0.5rem 0.75rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    color: var(--text);
    font-weight: 600;
  }

  .prose :global(td) {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  .prose :global(a) {
    color: var(--accent-light);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--text-muted);
    font-style: italic;
  }

  .prose :global(strong) {
    color: var(--text);
    font-weight: 700;
  }

  /* Gallery */
  .galeria {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .galeria h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

  .galeria-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }

  .galeria-grid img {
    border-radius: var(--radius);
    width: 100%;
    height: 200px;
    object-fit: cover;
    border: 1px solid var(--border);
  }
</style>
